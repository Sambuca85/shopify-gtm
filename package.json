    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "shopify:generate:extension": "shopify app generate extension",
    "shopify:deploy": "shopify app deploy",
    "shopify:logs": "shopify app logs",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@remix-run/node": "^2.8.0",
    "@remix-run/react": "^2.8.0",
    "@remix-run/serve": "^2.8.0",
    "@shopify/app-bridge-react": "^4.0.0",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^8.0.0",
    "@shopify/shopify-api": "^9.0.0",
    "@shopify/shopify-app-remix": "^2.5.0",
    "@shopify/shopify-app-session-storage-prisma": "^4.0.0",
    "crypto-js": "^4.2.0",
    "isbot": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ua-parser-js": "^1.0.37",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "date-fns": "^3.3.0",
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.8.0",
