    "@shopify/cli": "^3.59.0",
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^9.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "eslint": "^8.56.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
