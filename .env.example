# Shopify App Configuration
SHOPIFY_APP_URL=https://your-app-url.com
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SHOPIFY_API_VERSION=2024-01
SCOPES=read_products,read_orders,read_customers,write_pixels,read_pixels,write_themes,read_themes,write_script_tags,read_script_tags,write_checkout_ui_extensions

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gtm_tracking_app

# Session Secret
SESSION_SECRET=your_super_secret_session_key_min_32_chars

# GTM Configuration
GTM_DEFAULT_CONTAINER_ID=GTM-XXXXXX

# Webhook Secret
WEBHOOK_SECRET=your_webhook_secret

# Server Side Tracking
STSS_ENDPOINT=https://your-stss-server.com
META_CONVERSION_API_TOKEN=your_meta_token
TIKTOK_EVENTS_API_TOKEN=your_tiktok_token

# GDPR/Consent
GDPR_DEFAULT_REGION=EU
CONSENT_COOKIE_NAME=gtm_consent

# Debug
DEBUG_MODE=false
LOG_LEVEL=info

# Redis (optional, for event queue)
REDIS_URL=redis://localhost:6379

# Monitoring
SENTRY_DSN=your_sentry_dsn
